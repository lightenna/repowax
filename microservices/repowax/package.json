{
  "name": "repowax",
  "version": "0.5.14",
  "private": true,
  "dependencies": {
    "@hapi/boom": "^10.0.1",
    "app-root-path": "^3.1.0",
    "base-64": "^1.0.0",
    "body-parser": "^1.20.2",
    "child_process": "^1.0.2",
    "cookie-parser": "^1.4.6",
    "debug": "^4.3.4",
    "dotenv": "^16.0.3",
    "express": "^4.18.2",
    "http-errors": "^2.0.1",
    "morgan": "^1.10.0",
    "process": "^0.11.10",
    "slack-node": "^0.1.8",
    "url": "^0.11.0",
    "uuid": "^9.0.0",
    "winston": "^3.8.2"
  },
  "devDependencies": {
    "eslint": "^8.57.1",
    "gulp": "^4.0.2",
    "gulp-chmod": "^3.0.0",
    "gulp-clean": "^0.4.0",
    "gulp-install": "^1.1.0",
    "gulp-vinyl-zip": "^2.5.0",
    "gulp-zip": "^5.1.0",
    "merge-stream": "^2.0.0",
    "nodemon": "^2.0.22",
    "pkg": "^5.8.1",
    "proxyquire": "^2.1.3",
    "react-scripts": "^5.0.1",
    "supertest": "^6.3.3"
  },
  "bin": "bin/www",
  "pkg": {},
  "scripts": {
    "repowax-dev:win32": "set DEBUG=repowax:* && nodemon ./bin/www",
    "trigger-repw": "curl --data \"param1=value1&param2=value2\" -XPOST http://localhost:3001/repowax/my-repo",
    "update-all": "bash ./scripts/npm-update-all.sh",
    "test": "set CI=true && set DEBUG=repowax:* && react-scripts test -- --watchAll=false",
    "build-pkg": "npm version patch && pkg --targets linux,alpine,win,macos --output ../../dist-prod/repowax package.json",
    "lint": "eslint src/",
    "build-container": "bash ../../scripts/build.sh"
  }
}
